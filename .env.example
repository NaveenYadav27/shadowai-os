# Environment: development, staging, production
ENVIRONMENT=development

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Database
DATABASE_URL=postgresql://shadowai:shadowai_password@postgres:5432/shadowai_db
POSTGRES_USER=shadowai
POSTGRES_PASSWORD=shadowai_password
POSTGRES_DB=shadowai_db

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://elasticsearch:9200

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# AI Providers - Local First
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_ENABLED=false

LOCALAI_BASE_URL=http://localhost:8080
LOCALAI_ENABLED=false

# Optional AI Providers
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=false

GROQ_API_KEY=
GROQ_ENABLED=false

CLOUDFLARE_API_KEY=
CLOUDFLARE_ENABLED=false

HUGGINGFACE_API_KEY=
HUGGINGFACE_ENABLED=false

# Default Models (Capability-Based Routing)
DEFAULT_FRONTEND_MODEL=deepseek-coder
DEFAULT_BACKEND_MODEL=deepseek
DEFAULT_DOCUMENTATION_MODEL=llama2
DEFAULT_REASONING_MODEL=deepseek-r1
DEFAULT_SECURITY_MODEL=deepseek-r1

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_ENABLED=false

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_ENABLED=false

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# Plugin System
PLUGIN_DIRECTORY=./plugins
PLUGIN_ENABLED=true

# Backup & Versioning
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=3600

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_URL=/docs
REDOC_ENABLED=true

# Logging
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/shadowai.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10
